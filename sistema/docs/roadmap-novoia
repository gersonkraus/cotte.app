# Exemplo de lógica para Redis
import redis
import json

r = redis.from_url(os.getenv("REDIS_URL"))

def save_session(sessao_id, data):
    # Expira em 2 horas (7200s)
    r.setex(f"cotte_sess:{sessao_id}", 7200, json.dumps(data))

def get_session(sessao_id):
    data = r.get(f"cotte_sess:{sessao_id}")
    return json.loads(data) if data else {"messages": []}

