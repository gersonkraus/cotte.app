import anthropic
from app.core.config import settings
from .ai_tools_definition import get_tools_definition

client = anthropic.Anthropic(api_key=settings.ANTHROPIC_API_KEY)

async def executar_agente_cotte(mensagem_usuario, sessao_id, empresa_id):
    # 1. Busca histórico no Redis (Etapa 2 anterior)
    # messages = r.get_history(sessao_id)
    
    system_prompt = "Você é o Agente COTTE, assistente autônomo do ERP. Use as ferramentas para agir."
    
    # 2. Chamada com Prompt Caching (Economia de 90% no input repetido)
    response = client.messages.create(
        model="claude-3-5-sonnet-20240620",
        max_tokens=1024,
        system=[
            {
                "type": "text", 
                "text": system_prompt,
                "cache_control": {"type": "ephemeral"} # Ativa o Cache aqui
            }
        ],
        tools=get_tools_definition(),
        messages=[{"role": "user", "content": mensagem_usuario}]
    )

    # 3. O Loop de Tool Use (Raciocínio)
    if response.stop_reason == "tool_use":
        tool_use = next(block for block in response.content if block.type == "tool_use")
        tool_name = tool_use.name
        tool_input = tool_use.input

        # --- EXECUÇÃO DAS FERRAMENTAS ---
        # Aqui você conecta com seus services atuais do COTTE
        resultado_acao = f"Executando {tool_name} com os dados {tool_input}..."
        
        if tool_name == "consultar_saldo_caixa":
            # resultado_acao = financeiro_service.get_saldo(empresa_id)
            pass

        # 4. Devolve o resultado para a IA finalizar a resposta
        final_response = client.messages.create(
            model="claude-3-5-sonnet-20240620",
            max_tokens=512,
            messages=[
                {"role": "user", "content": mensagem_usuario},
                {"role": "assistant", "content": response.content},
                {
                    "role": "user", 
                    "content": [
                        {
                            "type": "tool_result",
                            "tool_use_id": tool_use.id,
                            "content": str(resultado_acao),
                        }
                    ],
                },
            ],
        )
        return final_response.content[0].text

    return response.content[0].text