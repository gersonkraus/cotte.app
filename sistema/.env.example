# App
APP_NAME=COTTE
APP_URL=https://cotte.app
ENVIRONMENT=production
CORS_ALLOWED_ORIGINS=https://cotte.app,https://www.cotte.app,http://localhost:8000,http://127.0.0.1:8000

# Uvicorn (Railway/Cloudflare): confiar X-Forwarded-Proto. release.sh define * por defeito.
# FORWARDED_ALLOW_IPS=*

# Banco de Dados
# No Railway, esta variável é preenchida automaticamente pelo serviço de banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/cotte

# Segurança
SECRET_KEY=sua_chave_secreta_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui

# WhatsApp Provider ("evolution" ou "zapi")
WHATSAPP_PROVIDER=evolution

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_INSTANCE=cotte

# Z-API (opcional se usar Evolution)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Admin
ADMIN_SETUP_KEY=chave_para_setup_inicial

# E-mail (Brevo recomendado na Railway)
BREVO_API_KEY=sua_chave_brevo_aqui
SMTP_FROM=COTTE <noreply@seudominio.com>

# Redis (opcional para cache/queues)
REDIS_URL=

# Cloudflare R2 (armazenamento)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Notion
NOTION_API_KEY=
NOTION_PAGE_ID=

# Prefixo da API
API_V1_STR=/api/v1

# === IA (LiteLLM) ===
# Provider aceitos atualmente: openrouter, openai, anthropic.
AI_PROVIDER=openrouter
# Para OpenRouter, use o modelo no formato "<vendor>/<model>".
# Ex.: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-001
AI_MODEL=openai/gpt-4o-mini
# Chave unificada usada pelo backend (prioritária se preenchida).
AI_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Fallbacks opcionais por provider (usados se AI_API_KEY estiver vazio):
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Tool Use v2 (function calling no /assistente)
USE_TOOL_CALLING=false
